<mxfile host="app.diagrams.net" type="device">
  <diagram name="Алгоритм поиска места" id="geo">
    <mxGraphModel dx="900" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Алгоритм поиска места и геокодирования (Mapbox)" style="text;html=1;align=center;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="20" width="540" height="30" as="geometry" />
        </mxCell>
        <mxCell id="start" value="Ввод названия места в форме пункта" style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="290" y="70" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="d0" value="Длина запроса ≥ 2&#10;и токен Mapbox задан?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="300" y="150" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="stop" value="Подсказки не показываются" style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="620" y="175" width="170" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p1" value="Задержка ввода 350 мс (debounce)" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="300" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="Запрос к Mapbox Geocoding API&#10;(язык ru, лимит 6)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="290" y="380" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="Список результатов:&#10;название, адрес, координаты (lng, lat)" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="470" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p4" value="Выбор результата → заполнить&#10;заголовок + lat/lng + address" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="560" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p5" value="Сохранить пункт с координатами" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="300" y="650" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="end" value="Пин на карте, цвет по дню" style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="300" y="730" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e0" style="endArrow=block;html=1;" edge="1" parent="1" source="start" target="d0"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e1" value="нет" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="d0" target="stop"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="да" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="d0" target="p1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" style="endArrow=block;html=1;" edge="1" parent="1" source="p1" target="p2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" style="endArrow=block;html=1;" edge="1" parent="1" source="p2" target="p3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" style="endArrow=block;html=1;" edge="1" parent="1" source="p3" target="p4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" style="endArrow=block;html=1;" edge="1" parent="1" source="p4" target="p5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" style="endArrow=block;html=1;" edge="1" parent="1" source="p5" target="end"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
