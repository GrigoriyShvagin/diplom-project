<mxfile host="app.diagrams.net" type="device">
  <diagram name="Алгоритм иерархической памяти" id="mem">
    <mxGraphModel dx="900" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Алгоритм свёртки памяти чата — ensureSummaries(tripId)" style="text;html=1;align=center;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="20" width="600" height="30" as="geometry" />
        </mxCell>
        <mxCell id="start" value="Начало (после отправки сообщения)" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="300" y="70" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p0" value="total ← число сообщений поездки&#10;covered ← граница последней сводки (toIndex)&#10;blockNumber ← номер последней сводки" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="150" width="300" height="70" as="geometry" />
        </mxCell>
        <mxCell id="d1" value="total − covered ≥ N ?&#10;(N = CHAT_SUMMARY_BLOCK_SIZE)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="290" y="260" width="260" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p1" value="Взять блок сообщений&#10;skip = covered, take = N" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="420" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="summarizeBlock(блок) →&#10;Claude (tool_use save_chat_summary):&#10;{mood, summary, topics, decisions, questions}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="270" y="520" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="Сохранить ChatSummary&#10;covered ← covered + N&#10;blockNumber ← blockNumber + 1" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="640" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="end" value="Конец" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="640" y="285" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e0" style="endArrow=block;html=1;" edge="1" parent="1" source="start" target="p0"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e1" style="endArrow=block;html=1;" edge="1" parent="1" source="p0" target="d1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="да" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="d1" target="p1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="нет" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="d1" target="end"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" style="endArrow=block;html=1;" edge="1" parent="1" source="p1" target="p2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" style="endArrow=block;html=1;" edge="1" parent="1" source="p2" target="p3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" value="цикл по блокам" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="p3" target="d1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="180" y="675" /><mxPoint x="180" y="315" /></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
